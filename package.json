{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test src/gasMath.test.js",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android",
    "cap:open:android": "cap open android",
    "cap:ios": "npm run build && cap sync ios",
    "cap:open:ios": "cap open ios",
    "mobile:assets": "capacitor-assets generate"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "mysql2": "^3.22.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
